# ============================================================
# BYOCORE 브랜드몰 운영 보고 에이전트 — 환경변수 템플릿
# 사용법: 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
#   PowerShell:  Copy-Item .env.example .env
# 주의: .env 는 git 에 커밋되지 않습니다(.gitignore).
# ============================================================

# ===== Cafe24 (브랜드몰 / Admin API) =====
# 기존 GEO 앱 재사용. scope: 주문(Order) 읽기.
CAFE24_MALL_ID=
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_REDIRECT_URI=

# ===== Kakao (나에게 보내기) =====
# 동의항목(scope): talk_message
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=

# ===== GEO 인용률 (Google Sheet, 읽기 전용) =====
# 기본값 = RECON 확정 시트 ID (비워두면 config.py 기본값 사용)
GEO_SHEET_ID=18rrHs_ifXSxZlY3mboRftCXO3KRl3JRBnZ2P-c2ufZA
# 서비스 계정 키 파일 경로 또는 JSON 문자열
GOOGLE_SERVICE_ACCOUNT_JSON=

# ===== 경쟁동향 (market repo 로컬 clone) =====
# repo: ever-90/market-insight-byocore  → 로컬 clone 경로
MARKET_REPO_PATH=

# ===== 자동 발급 토큰 (auth 스크립트가 채움 — 수동 입력 불필요) =====
CAFE24_ACCESS_TOKEN=
CAFE24_REFRESH_TOKEN=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
